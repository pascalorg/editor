# Azure OpenAI deployment endpoint.
AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenRouter chat completions endpoint (used when AI_PROVIDER is omitted).
# You can still use AI_API_KEY / AI_BASE_URL / AI_MODEL aliases, but these
# OpenRouter names are preferred.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=~openai/gpt-5.5
OPENROUTER_FALLBACK_API_KEY=
OPENROUTER_FALLBACK_MODEL=
OPENROUTER_HTTP_REFERER=http://localhost:8788
OPENROUTER_APP_TITLE=Pascal AI MCP
OPENROUTER_TEMPERATURE=0.2

# HTTP server for this chat bridge.
AI_MCP_HOST=127.0.0.1
AI_MCP_PORT=8788

# Where this bridge stores chat history. Leave unset to use ./.data/sessions.json.
AI_MCP_SESSION_FILE=

# MCP connection mode: http or stdio.
PASCAL_MCP_MODE=stdio

# Set PASCAL_MCP_MODE=http when Pascal MCP already runs separately, for example:
# bun packages/mcp/src/bin/pascal-mcp.ts --http --port 3917
PASCAL_MCP_URL=http://127.0.0.1:3917/mcp
PASCAL_MCP_TOKEN=

# Stdio mode starts a Pascal MCP process from this bridge.
PASCAL_MCP_COMMAND=bun
PASCAL_MCP_ARGS=../packages/mcp/src/bin/pascal-mcp.ts --stdio
PASCAL_DATA_DIR=

# Agent loop guard.
AI_MCP_MAX_TOOL_ROUNDS=8

# Input workflow limits. Confidence thresholds remain configurable until the
# production image/text evaluation set has been calibrated.
AI_MAX_CLARIFICATION_ROUNDS=3
AI_MAX_REPAIR_ROUNDS=2
AI_USABLE_CONFIDENCE=0.80
AI_PARTIAL_CONFIDENCE=0.50
